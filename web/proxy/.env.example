# Astronomical Mount Controller Web Proxy Configuration

# gRPC backend connection (Mount Controller)
GRPC_HOST=localhost
GRPC_PORT=50051

# gRPC backend connection (Object Database)
DB_GRPC_HOST=localhost
DB_GRPC_PORT=50052

# Proxy server settings
PROXY_PORT=8080
PROXY_HOST=0.0.0.0

# SSL/TLS (optional)
ENABLE_SSL=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8080

# Logging
LOG_LEVEL=dev
